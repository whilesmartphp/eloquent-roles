{
  "name": "whilesmart/eloquent-roles",
  "description": "Flexible roles and permissions package for Laravel applications",
  "package-version": "1.0.1",
  "keywords": [
    "laravel",
    "roles",
    "permissions",
    "php",
    "package",
    "rbac"
  ],
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Whilesmart Team"
    }
  ],
  "require": {
    "php": "^8.2",
    "cviebrock/eloquent-sluggable": "^11.0|^12.0",
    "laravel/framework": "^11.0|^12.0"
  },
  "require-dev": {
    "fakerphp/faker": "^1.24",
    "laravel/pint": "^1.25",
    "orchestra/testbench": "^9.0|^10.0",
    "phpunit/phpunit": "^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "Whilesmart\\Roles\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Whilesmart\\Roles\\Tests\\": "tests/",
      "Workbench\\App\\": "workbench/app/",
      "Workbench\\Database\\Factories\\": "workbench/database/factories/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Whilesmart\\Roles\\RolesServiceProvider"
      ]
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "@clear",
      "@prepare"
    ],
    "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
    "prepare": "@php vendor/bin/testbench package:discover --ansi",
    "build": "@php vendor/bin/testbench workbench:build --ansi",
    "serve": [
      "Composer\\Config::disableProcessTimeout",
      "@build",
      "@php vendor/bin/testbench serve --ansi"
    ],
    "pint": [
      "./vendor/bin/pint"
    ],
    "pint:test": [
      "./vendor/bin/pint --test"
    ]
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
